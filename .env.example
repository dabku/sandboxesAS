# Copy this to .env and fill in your OpenRouter API key
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Model to use (default: minimax/minimax-m2.7)
OPENROUTER_MODEL=minimax/minimax-m2.7

# Daytona Sandbox (used in demo7)
# Get your API key at https://app.daytona.io/dashboard/keys
DAYTONA_API_KEY=your-daytona-api-key-here
DAYTONA_API_URL=https://app.daytona.io/api

# These simulate secrets that a real app would have
# (used in demo3 to show env var leaking)
